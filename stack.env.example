# ╔══════════════════════════════════════════════════════════════════╗
# ║  OpenHamClock — Docker Quick Start                              ║
# ║                                                                  ║
# ║  Copy this file to stack.env (for Portainer) or .env:            ║
# ║    cp stack.env.example stack.env                                ║
# ║                                                                  ║
# ║  Only uncomment what you need. Everything has sensible defaults. ║
# ║  For ALL available options, see .env.example                     ║
# ╚══════════════════════════════════════════════════════════════════╝

# ── Your Station (recommended) ────────────────────────────────────

CALLSIGN=N0CALL
LOCATOR=FN31
#LATITUDE=
#LONGITUDE=

# ── Timezone ──────────────────────────────────────────────────────
# Set this! Docker containers default to UTC.
# https://en.wikipedia.org/wiki/List_of_tz_database_time_zones

#TZ=America/New_York

# ── Display ───────────────────────────────────────────────────────

#UNITS=imperial
#TIME_FORMAT=12
#THEME=dark

# ── API Keys (optional) ──────────────────────────────────────────

#OPENWEATHER_API_KEY=
#VITE_OPENWEATHER_API_KEY=
